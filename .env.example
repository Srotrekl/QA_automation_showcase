# =============================================================================
# QA Automation Showcase — Environment Variables
# =============================================================================
# Zkopíruj tento soubor jako .env a uprav hodnoty dle potřeby:
#   cp .env.example .env
#
# NIKDY necommituj .env soubor — obsahuje credentials!
# =============================================================================

# --- SauceDemo (UI testy) ---
UI_BASE_URL=https://www.saucedemo.com
UI_USERNAME=standard_user
UI_PASSWORD=secret_sauce

# --- Restful Booker (API testy) ---
API_BASE_URL=https://restful-booker.herokuapp.com
API_USERNAME=admin
API_PASSWORD=password123

# --- Browser konfigurace ---
# Podporované: chromium, firefox, webkit
BROWSER=chromium
HEADLESS=true
